{
    "name": "modules/lastorder-attendance",
    "description": "Daily attendance check-in and point reward module for Gnuboard7",
    "type": "library",
    "version": "1.0.1",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Modules\\Lastorder\\Attendance\\": "src/",
            "Modules\\Lastorder\\Attendance\\Database\\Seeders\\": "database/seeders/",
            "Modules\\Lastorder\\Attendance\\Database\\Factories\\": "database/factories/",
            "Modules\\Lastorder\\Attendance\\Upgrades\\": "upgrades/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Modules\\Lastorder\\Attendance\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "nesbot/carbon": "^2.0 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0",
        "mockery/mockery": "^1.6",
        "illuminate/http": "^11.0 || ^12.0"
    }
}
