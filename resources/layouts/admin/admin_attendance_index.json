{
    "version": "1.0.0",
    "layout_name": "admin_attendance_index",
    "permissions": ["lastorder-attendance.attendance.read"],
    "extends": "_admin_base",
    "meta": {
        "title": "$t:lastorder-attendance.admin.attendance.title"
    },
    "state": {},
    "initLocal": {
        "selectedDate": null,
        "recalcUserId": "",
        "showRecalcModal": false,
        "recalcType": "",
        "isRecalculating": false
    },
    "data_sources": [
        {
            "id": "attendances",
            "type": "api",
            "endpoint": "/api/modules/lastorder-attendance/admin/attendance",
            "method": "GET",
            "auto_fetch": true,
            "auth_required": true,
            "refetchOnMount": true,
            "params": {
                "date": "{{query.date ?? ''}}",
                "page": "{{query.page ?? 1}}",
                "per_page": "{{query.per_page ?? 20}}"
            },
            "cache": false,
            "errorHandling": {
                "403": {
                    "handler": "showErrorPage",
                    "params": { "target": "content" }
                }
            },
            "fallback": {
                "data": {
                    "data": []
                }
            }
        }
    ],
    "computed": {
        "attendanceList": "{{attendances?.data?.data ?? []}}",
        "totalCount": "{{attendances?.data?.meta?.total ?? 0}}",
        "currentPage": "{{attendances?.data?.meta?.current_page ?? 1}}",
        "lastPage": "{{attendances?.data?.meta?.last_page ?? 1}}"
    },
    "slots": {
        "content": [
            {
                "id": "admin_attendance_page",
                "type": "basic",
                "name": "Div",
                "props": {
                    "className": "p-4 sm:p-6 lg:p-8 bg-gray-50 dark:bg-gray-900 min-h-screen"
                },
                "children": [
                    {
                        "id": "page_header",
                        "type": "composite",
                        "name": "PageHeader",
                        "props": {
                            "title": "$t:lastorder-attendance.admin.attendance.title",
                            "description": "{{_computed.totalCount + ' records'}}"
                        }
                    },
                    {
                        "id": "summary_cards",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6 mb-6"
                        },
                        "children": [
                            {
                                "id": "card_total_today",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 shadow-sm"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
                                        "text": "$t:lastorder-attendance.admin.attendance.summary.total_today"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": { "className": "text-2xl font-bold text-gray-900 dark:text-white mt-1" },
                                        "text": "{{_computed.totalCount}}"
                                    }
                                ]
                            },
                            {
                                "id": "card_date",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 shadow-sm"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
                                        "text": "$t:lastorder-attendance.admin.attendance.date_filter"
                                    },
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": { "className": "text-2xl font-bold text-gray-900 dark:text-white mt-1" },
                                        "text": "{{query.date || new Date().toISOString().split('T')[0]}}"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "filters_bar",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "flex flex-col sm:flex-row items-stretch sm:items-center gap-3 mb-6 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-4 shadow-sm"
                        },
                        "children": [
                            {
                                "id": "date_filter",
                                "type": "basic",
                                "name": "Input",
                                "props": {
                                    "type": "date",
                                    "value": "{{query.date || new Date().toISOString().split('T')[0]}}",
                                    "className": "px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm"
                                },
                                "actions": [
                                    {
                                        "type": "change",
                                        "handler": "navigate",
                                        "params": {
                                            "path": "{{route.path}}",
                                            "mergeQuery": true,
                                            "query": {
                                                "date": "{{$event.target.value}}",
                                                "page": 1
                                            }
                                        }
                                    }
                                ]
                            },
                            {
                                "id": "recalc_section",
                                "type": "basic",
                                "name": "Div",
                                "props": {
                                    "className": "flex items-center gap-2 ml-auto"
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Label",
                                        "props": { "className": "text-sm font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap" },
                                        "text": "$t:lastorder-attendance.admin.attendance.user_id"
                                    },
                                    {
                                        "id": "recalc_user_id_input",
                                        "type": "basic",
                                        "name": "Input",
                                        "props": {
                                            "type": "number",
                                            "min": 1,
                                            "value": "{{_local.recalcUserId}}",
                                            "placeholder": "ID",
                                            "className": "w-24 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm"
                                        },
                                        "actions": [
                                            {
                                                "type": "change",
                                                "handler": "setState",
                                                "params": {
                                                    "target": "local",
                                                    "recalcUserId": "{{$event.target.value}}"
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "id": "recalc_consecutive_btn",
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "disabled": "{{!_local.recalcUserId || _local.isRecalculating}}",
                                            "className": "px-3 py-2 bg-amber-500 hover:bg-amber-600 disabled:bg-gray-400 text-white rounded-lg text-xs font-medium transition-colors whitespace-nowrap"
                                        },
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "sequence",
                                                "actions": [
                                                    {
                                                        "handler": "setState",
                                                        "params": { "target": "local", "isRecalculating": true }
                                                    },
                                                    {
                                                        "handler": "apiCall",
                                                        "auth_required": true,
                                                        "target": "/api/modules/lastorder-attendance/admin/attendance/recalculate-consecutive/{{_local.recalcUserId}}",
                                                        "params": { "method": "POST" },
                                                        "onSuccess": [
                                                            {
                                                                "handler": "setState",
                                                                "params": { "target": "local", "isRecalculating": false }
                                                            },
                                                            {
                                                                "handler": "toast",
                                                                "params": { "type": "success", "message": "$t:lastorder-attendance.admin.attendance.recalculated" }
                                                            },
                                                            {
                                                                "handler": "refetchDataSource",
                                                                "params": { "dataSourceId": "attendances" }
                                                            }
                                                        ],
                                                        "onError": [
                                                            {
                                                                "handler": "setState",
                                                                "params": { "target": "local", "isRecalculating": false }
                                                            },
                                                            {
                                                                "handler": "toast",
                                                                "params": { "type": "error", "message": "{{error.message}}" }
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ],
                                        "text": "$t:lastorder-attendance.admin.attendance.recalculate_consecutive"
                                    },
                                    {
                                        "id": "recalc_total_btn",
                                        "type": "basic",
                                        "name": "Button",
                                        "props": {
                                            "disabled": "{{!_local.recalcUserId || _local.isRecalculating}}",
                                            "className": "px-3 py-2 bg-amber-500 hover:bg-amber-600 disabled:bg-gray-400 text-white rounded-lg text-xs font-medium transition-colors whitespace-nowrap"
                                        },
                                        "actions": [
                                            {
                                                "type": "click",
                                                "handler": "sequence",
                                                "actions": [
                                                    {
                                                        "handler": "setState",
                                                        "params": { "target": "local", "isRecalculating": true }
                                                    },
                                                    {
                                                        "handler": "apiCall",
                                                        "auth_required": true,
                                                        "target": "/api/modules/lastorder-attendance/admin/attendance/recalculate-total/{{_local.recalcUserId}}",
                                                        "params": { "method": "POST" },
                                                        "onSuccess": [
                                                            {
                                                                "handler": "setState",
                                                                "params": { "target": "local", "isRecalculating": false }
                                                            },
                                                            {
                                                                "handler": "toast",
                                                                "params": { "type": "success", "message": "$t:lastorder-attendance.admin.attendance.recalculated" }
                                                            },
                                                            {
                                                                "handler": "refetchDataSource",
                                                                "params": { "dataSourceId": "attendances" }
                                                            }
                                                        ],
                                                        "onError": [
                                                            {
                                                                "handler": "setState",
                                                                "params": { "target": "local", "isRecalculating": false }
                                                            },
                                                            {
                                                                "handler": "toast",
                                                                "params": { "type": "error", "message": "{{error.message}}" }
                                                            }
                                                        ]
                                                    }
                                                ]
                                            }
                                        ],
                                        "text": "$t:lastorder-attendance.admin.attendance.recalculate_total"
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "attendance_table_wrapper",
                        "type": "basic",
                        "name": "Div",
                        "props": {
                            "className": "bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm overflow-hidden"
                        },
                        "children": [
                            {
                                "id": "attendance_table",
                                "type": "composite",
                                "name": "DataGrid",
                                "props": {
                                    "columns": [
                                        {
                                            "field": "id",
                                            "header": "ID",
                                            "width": "w-16"
                                        },
                                        {
                                            "field": "daily_rank",
                                            "header": "$t:lastorder-attendance.user.table.rank",
                                            "width": "w-16"
                                        },
                                        {
                                            "field": "user.name",
                                            "header": "$t:lastorder-attendance.user.table.nickname"
                                        },
                                        {
                                            "field": "attendance_time",
                                            "header": "$t:lastorder-attendance.user.table.time",
                                            "width": "w-24"
                                        },
                                        {
                                            "field": "greeting",
                                            "header": "$t:lastorder-attendance.user.table.greeting"
                                        },
                                        {
                                            "field": "base_point",
                                            "header": "$t:lastorder-attendance.user.table.point",
                                            "width": "w-20"
                                        },
                                        {
                                            "field": "random_point",
                                            "header": "$t:lastorder-attendance.user.table.random_point",
                                            "width": "w-28"
                                        },
                                        {
                                            "field": "consecutive_days",
                                            "header": "$t:lastorder-attendance.user.table.consecutive",
                                            "width": "w-20"
                                        },
                                        {
                                            "field": "total_days",
                                            "header": "$t:lastorder-attendance.user.table.total_days",
                                            "width": "w-24"
                                        },
                                        {
                                            "field": "_actions",
                                            "header": "",
                                            "width": "w-20",
                                            "cellChildren": [
                                                {
                                                    "type": "basic",
                                                    "name": "Button",
                                                    "props": {
                                                        "className": "px-2 py-1 bg-red-500 hover:bg-red-600 text-white rounded text-xs transition-colors"
                                                    },
                                                    "actions": [
                                                        {
                                                            "type": "click",
                                                            "handler": "sequence",
                                                            "actions": [
                                                                {
                                                                    "handler": "confirm",
                                                                    "params": {
                                                                        "message": "$t:lastorder-attendance.admin.attendance.delete_confirm"
                                                                    }
                                                                },
                                                                {
                                                                    "handler": "apiCall",
                                                                    "auth_required": true,
                                                                    "target": "/api/modules/lastorder-attendance/admin/attendance/{{row.id}}",
                                                                    "params": { "method": "DELETE" },
                                                                    "onSuccess": [
                                                                        {
                                                                            "handler": "toast",
                                                                            "params": { "type": "success", "message": "$t:lastorder-attendance.admin.attendance.deleted" }
                                                                        },
                                                                        {
                                                                            "handler": "refetchDataSource",
                                                                            "params": { "dataSourceId": "attendances" }
                                                                        }
                                                                    ],
                                                                    "onError": [
                                                                        {
                                                                            "handler": "toast",
                                                                            "params": { "type": "error", "message": "{{error.message}}" }
                                                                        }
                                                                    ]
                                                                }
                                                            ]
                                                        }
                                                    ],
                                                    "text": "$t:lastorder-attendance.admin.attendance.delete"
                                                }
                                            ]
                                        }
                                    ],
                                    "data": "{{_computed.attendanceList}}",
                                    "emptyMessage": "$t:lastorder-attendance.admin.attendance.no_data",
                                    "className": "w-full"
                                }
                            },
                            {
                                "id": "admin_pagination",
                                "type": "composite",
                                "name": "Pagination",
                                "if": "{{_computed.lastPage > 1}}",
                                "props": {
                                    "currentPage": "{{_computed.currentPage}}",
                                    "lastPage": "{{_computed.lastPage}}",
                                    "total": "{{_computed.totalCount}}",
                                    "className": "p-4 border-t border-gray-200 dark:border-gray-700"
                                },
                                "actions": [
                                    {
                                        "type": "pageChange",
                                        "handler": "navigate",
                                        "params": {
                                            "path": "{{route.path}}",
                                            "mergeQuery": true,
                                            "query": {
                                                "page": "{{$event.page}}"
                                            }
                                        }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
