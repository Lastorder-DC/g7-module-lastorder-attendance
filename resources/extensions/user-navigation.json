{
    "target_layout": "_user_base",
    "injections": [
        {
            "target_id": "mobile_nav_drawer",
            "position": "append_child",
            "components": [
                {
                    "id": "attendance_mobile_nav_section",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                        "className": "px-4 pb-4 border-b border-gray-200 dark:border-gray-700"
                    },
                    "children": [
                        {
                            "type": "basic",
                            "name": "Div",
                            "props": {
                                "className": "text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 px-3"
                            },
                            "text": "$t:lastorder-attendance.user.nav.section_title"
                        },
                        {
                            "type": "basic",
                            "name": "Button",
                            "props": {
                                "className": "w-full flex items-center justify-start gap-3 px-3 py-2.5 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg cursor-pointer"
                            },
                            "actions": [
                                {
                                    "type": "click",
                                    "handler": "sequence",
                                    "actions": [
                                        {
                                            "handler": "setState",
                                            "params": {
                                                "target": "global",
                                                "mobileMenuOpen": false
                                            }
                                        },
                                        {
                                            "handler": "navigate",
                                            "params": {
                                                "path": "/attendance"
                                            }
                                        }
                                    ]
                                }
                            ],
                            "children": [
                                {
                                    "type": "basic",
                                    "name": "Icon",
                                    "props": {
                                        "name": "calendar-check",
                                        "className": "w-5 h-5"
                                    }
                                },
                                {
                                    "type": "basic",
                                    "name": "Span",
                                    "text": "$t:lastorder-attendance.user.nav.attendance"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        {
            "target_id": "desktop_header",
            "position": "inject_props",
            "props": {
                "extraMenuItems": {
                    "_append": [
                        {
                            "label": "$t:lastorder-attendance.user.nav.attendance",
                            "href": "/attendance",
                            "icon": "calendar-check"
                        }
                    ]
                }
            }
        }
    ],
    "priority": 200
}
